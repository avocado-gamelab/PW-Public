<?xml version="1.0" encoding="utf-8"?>
<UnitConstant>
	<BackLink DBID="/Items/Talents/Common/G547_SilenceDamageBase.TALENT" Count="1" />
	<name>G547_Duration</name>
	<var>
		<compiledString></compiledString>
		<returnType>float</returnType>
		<sString>min(cG547_BaseDuration + (sender.vG577_Active &gt; 0 ? cG577_Duration : 0) + (sender.vG548_Active &gt; 0 ? cG547_DurationBonus : 0) + (sender.vG549_Active &gt; 0 ? cG547_DurationBonus: 0) + (sender.vG550_Active &gt; 0 ? cG547_DurationBonus : 0), cG547_MaxDuration)</sString>
	</var>
</UnitConstant>