<?xml version="1.0" encoding="utf-8"?>
<UnitConstant>
	<BackLink DBID="/Items/Talents/Common/G766_MiniRefresher.TALENT" Count="1" />
	<name>G766_Cooldown</name>
	<var>
		<compiledString></compiledString>
		<returnType>float</returnType>
		<sString>(tal("G773") ? 50 - sender.vG773_Active * cG773_CooldownReduction : 50) * (1.0f - sender.vTotal_CooldownReduction * 0.01f)</sString>
	</var>
</UnitConstant>