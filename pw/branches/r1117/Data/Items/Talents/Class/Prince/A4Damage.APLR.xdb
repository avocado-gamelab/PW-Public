	<BackLink DBID="/Items/Talents/Class/Prince/A4ShotB.APLR" Count="1" />
	<applyTarget>ApplicatorTarget</applyTarget>
	<cancelInvisibility>false</cancelInvisibility>
	<caption>урон</caption>
	<damage>
		<compiledString></compiledString>
		<returnType>float</returnType>
		<sString>cA4_Damage * min(max(cMinDamagePercent + (cMaxDamagePercent - cMinDamagePercent) * (1.0f - ((d(sPos, rPos) - cMaxDamageRange) / (cMinDamageRange - cMaxDamageRange))), cMinDamagePercent), cMaxDamagePercent) * 0.01</sString>
	</damage>
	<damageMode>4</damageMode>
	<damageType>Energy</damageType>
	<enabled>
		<compiledString></compiledString>
		<returnType>bool</returnType>
		<sString>true</sString>
	</enabled>
	<formulaName></formulaName>
	<LoggingEvent>-1</LoggingEvent>
	<providerName></providerName>
	<timeLimiter>-1</timeLimiter>
	<uiEvent href="/UI/Events/CommonEvents/EventDamageDealed_Energy.UIEV" />
