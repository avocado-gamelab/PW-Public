<UnitConstant>
	<BackLink DBID="/Heroes/Vampire/_.HROB" Count="1" />
	<BackLink DBID="/Items/Talents/Class/Vampire/Ability_A0.TALENT" Count="1" />
	<BackLink DBID="/Items/Talents/Class/Vampire/Ability_A1.TALENT" Count="1" />
	<BackLink DBID="/Items/Talents/Class/Vampire/Ability_A2.TALENT" Count="1" />
	<BackLink DBID="/Items/Talents/Class/Vampire/Ability_A3.TALENT" Count="1" />
	<BackLink DBID="/Items/Talents/Class/Vampire/Ability_A4.TALENT" Count="1" />
	<BackLink DBID="/Items/Talents/Class/Vampire/Ability_A4_2.TALENT" Count="1" />
	<BackLink DBID="/Items/Talents/Class/Vampire/Ability_A0_SUP.TALENT" Count="1" />
	<name>A0_LifeDrainPercent</name>
	<var>
		<compiledString></compiledString>
		<returnType>float</returnType>
		<sString>cA0_BaseLifeDrainPercent * (1 + (sender.applVampire_EternalHunger(UNIT) != pMisc) * (cA0_SUP_LifeDrainMultiplier - 1))</sString>
	</var>
</UnitConstant>