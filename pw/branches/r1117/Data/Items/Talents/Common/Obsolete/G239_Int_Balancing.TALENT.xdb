							<returnType>float</returnType>
							<sString>(1 - sLife / sMaxLife) * 100</sString>
						</var>
					</UnitConstant>
				</Item>
				<Item href="/Items/Talents/Common/Obsolete/G239_Int_Balancing.TALENT" id="2AECC2B4-1B37-4F71-8625-11819850420F">
