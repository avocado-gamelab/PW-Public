					<UnitConstant>
						<name>TECH_Add_Int_Bal</name>
						<var>
							<compiledString></compiledString>
							<returnType>float</returnType>
							<sString>(cTECH_CurrentMissingLifePercent - fmod(cTECH_CurrentMissingLifePercent, cTECH_LifeStepPercent)) / cTECH_LifeStepPercent * cTECH_IntStep</sString>
						</var>
					</UnitConstant>
				</Item>
				<Item href="/Items/Talents/Common/Obsolete/G239_Int_Balancing.TALENT" id="9D776DD8-71B8-4597-9482-D06AAA537E37">
