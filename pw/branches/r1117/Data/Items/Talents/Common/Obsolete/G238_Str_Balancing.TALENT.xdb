					<UnitConstant>
						<name>TECH_Add_Str_Bal</name>
						<var>
							<compiledString></compiledString>
							<returnType>float</returnType>
							<sString>(cTECH_CurrentMissingLifePercent - fmod(cTECH_CurrentMissingLifePercent, cTECH_LifeStepPercent)) / cTECH_LifeStepPercent * cTECH_StrStep</sString>
						</var>
					</UnitConstant>
				</Item>
				<Item href="/Items/Talents/Common/Obsolete/G238_Str_Balancing.TALENT" id="7C7C3DDC-4D79-44EB-84DC-BC35DF7D232F">
