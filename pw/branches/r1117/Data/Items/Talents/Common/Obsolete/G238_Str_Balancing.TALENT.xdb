							<returnType>float</returnType>
							<sString>(1 - sLife / sMaxLife) * 100</sString>
						</var>
					</UnitConstant>
				</Item>
				<Item href="/Items/Talents/Common/Obsolete/G238_Str_Balancing.TALENT" id="F5F6ADAF-D878-435D-874A-0094D890801D">
