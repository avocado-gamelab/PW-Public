					<sString>-1.0</sString>
				</lifeTime>
				<LoggingEvent>-1</LoggingEvent>
				<modifier>
					<addValue>
						<compiledString></compiledString>
						<returnType>float</returnType>
						<sString>min(
	sender.vGameDuration / 60 *  
	sender.FindApplicator( "AllyCreeps", pMisc, UNIT )-&gt;GetVariable("targetsCount") * 
	0.2 
,40) *
	(sender.FindApplicator( "AllyHeroes", pMisc, UNIT )-&gt;GetVariable("targetsCount") == 1 ? 1 : 
		sender.FindApplicator( "AllyHeroes", pMisc, UNIT )-&gt;GetVariable("targetsCount") == 2 ? 0.9 : 
		sender.FindApplicator( "AllyHeroes", pMisc, UNIT )-&gt;GetVariable("targetsCount") == 3 ? 0.75 : 
		sender.FindApplicator( "AllyHeroes", pMisc, UNIT )-&gt;GetVariable("targetsCount") == 4 ? 0.6 : 0.5)</sString>
					</addValue>
					<multValue>
						<compiledString>FQAAAAAAAAAAVYvs2e5dwwAAAAA=</compiledString>
						<returnType>float</returnType>
						<sString>0</sString>
					</multValue>
