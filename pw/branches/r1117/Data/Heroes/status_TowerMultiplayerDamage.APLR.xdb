		<Item href="/Heroes/status_TowerMultiplayerDamage.APLR" id="8C3FA590-7393-45AA-8C3D-E0C8A6C5A436">
			<StatModApplicator>
				<applyTarget>ApplicatorTarget</applyTarget>
				<behaviorFlags>0</behaviorFlags>
				<caption>TowerDamgeBuff</caption>
				<constraint>None</constraint>
				<dontUpdate>false</dontUpdate>
				<effect>
					<Item href="" />
					<Item href="" />
				</effect>
				<enabled>
					<compiledString></compiledString>
